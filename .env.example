# .env.example
# Copiar este archivo como .env y llenar con tus credenciales
# Para usar con Gmail: generar contraseña de aplicación en https://myaccount.google.com/apppasswords

# Credenciales de Gmail para envío de correos
GMAIL_USER=tu_email@gmail.com
GMAIL_PASSWORD=tu_contraseña_de_aplicación

# NOTA IMPORTANTE:
# - GMAIL_USER debe ser un correo de Gmail (ej: alexi.fs341@gmail.com)
# - GMAIL_PASSWORD debe ser una contraseña de aplicación (NO tu contraseña normal)
# - Génera una en: https://myaccount.google.com/apppasswords
# - Necesitas 2FA (Autenticación de Dos Factores) activado en tu cuenta de Google
